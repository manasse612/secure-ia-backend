# ============================================================
# Secure IA — Configuration Production (VPS)
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- Mode ---
DEBUG=false

# --- URLs (remplacer par votre domaine ou IP du VPS) ---
APP_URL=https://votre-domaine.com
BACKEND_URL=https://votre-domaine.com

# --- Base de données PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://secure_ia_user:MOT_DE_PASSE_FORT@localhost:5432/secure_ia
DATABASE_URL_SYNC=postgresql://secure_ia_user:MOT_DE_PASSE_FORT@localhost:5432/secure_ia

# --- Cache Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Authentification JWT (CHANGER CETTE CLÉ !) ---
SECRET_KEY=GENERER_UNE_CLE_SECRETE_ALEATOIRE_DE_64_CARACTERES
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OAuth Google (optionnel) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- APIs externes ---
HIVE_API_KEY=votre_cle_hive_ai
OPENAI_API_KEY=votre_cle_openai
VIRUSTOTAL_API_KEY=votre_cle_virustotal

# --- Stripe (optionnel, laisser vide = mode simulation) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
