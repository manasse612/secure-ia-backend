# === Configuration de la base de données ===
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/secure_ia
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/secure_ia

# === Configuration Redis ===
REDIS_URL=redis://localhost:6379/0

# === Clé secrète pour JWT ===
SECRET_KEY=votre-cle-secrete-tres-longue-et-aleatoire
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Configuration OAuth Google ===
GOOGLE_CLIENT_ID=votre-google-client-id
GOOGLE_CLIENT_SECRET=votre-google-client-secret

# === APIs externes ===
HIVE_API_KEY=votre-cle-hive-ai
OPENAI_API_KEY=votre-cle-openai
VIRUSTOTAL_API_KEY=votre-cle-virustotal

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_votre-cle-stripe
STRIPE_WEBHOOK_SECRET=whsec_votre-webhook-secret
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_BUSINESS=price_business_id

# === Chiffrement des données (RGPD) ===
# Générer avec: python -c "import base64; import os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=votre-cle-base64-32-bytes-genere-avec-commande-ci-dessus

# === Application ===
APP_NAME=Secure IA
APP_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
DEBUG=True
